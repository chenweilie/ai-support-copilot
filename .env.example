# ─── Required ────────────────────────────────────────────────────────────────

# OpenAI API Key (required for LLM pipeline)
OPENAI_API_KEY=sk-...

# ─── Google Sheets Integration ───────────────────────────────────────────────

# Option A: Set credentials as JSON string (recommended for Docker/CI)
GOOGLE_CREDS_JSON={"type": "service_account", "project_id": "...", ...}

# Option B: Path to credentials JSON file (local development)
GOOGLE_CREDS_PATH=credentials.json

# The Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Sheet tab name (will be created if it doesn't exist)
GOOGLE_SHEET_NAME=Tickets

# ─── Slack Integration ───────────────────────────────────────────────────────

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack Signing Secret (for webhook verification)
SLACK_SIGNING_SECRET=...

# Target channel for notifications
SLACK_CHANNEL=#support-copilot

# ─── Pipeline Configuration ──────────────────────────────────────────────────

# Confidence threshold below which tickets go to human review (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.75

# LLM model to use
OPENAI_MODEL=gpt-4o-mini

# ─── App Configuration ───────────────────────────────────────────────────────

LOG_LEVEL=INFO
DEBUG=false
